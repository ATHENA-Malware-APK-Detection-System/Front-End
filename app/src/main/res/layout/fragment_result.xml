<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="40dp"
    android:background="@color/light_pink"
    tools:context=".ResultFragment">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="@string/backbtn"
            android:src="@drawable/arrow"
            android:scaleType="fitCenter"
            android:backgroundTint="@color/light_pink"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/result"
            android:textSize="22sp"
            android:fontFamily="@font/inter_bold"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:gravity="center" />

        <!-- Spacer to balance back button -->
        <View
            android:layout_width="40dp"
            android:layout_height="40dp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="22dp"
        android:paddingBottom="24dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/btnScanAnother"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Result Icon Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardResultIcon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="15dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingVertical="30dp"
                    android:paddingHorizontal="24dp">

                    <!-- Icon Circle -->
                    <ImageView
                        android:id="@+id/ivResultIcon"
                        android:layout_width="140dp"
                        android:layout_height="140dp"
                        android:layout_gravity="center"
                        android:src="@drawable/checklist" />

                    <TextView
                        android:id="@+id/tvResultStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BENIGN"
                        android:textSize="20sp"
                        android:fontFamily="@font/inter_bold"
                        android:textStyle="bold"
                        android:textColor="@color/black80"
                        android:layout_marginTop="12dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- File Info Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardFileInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginHorizontal="10dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="20dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="File Information"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_bold"
                        android:textColor="@color/black80"
                        android:layout_marginBottom="20dp" />

                    <!-- File Name Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="File Name"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter_semibold"
                            android:textColor="@color/black" />

                        <TextView
                            android:id="@+id/tvFileName"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.5"
                            android:text="app-release.apk"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter_light"
                            android:textColor="@color/black"
                            android:gravity="end"
                            android:ellipsize="middle"
                            android:singleLine="true" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/black80"
                        android:layout_marginBottom="10dp" />

                    <!-- File Size Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="File Size"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter_semibold"
                            android:textColor="@color/black" />

                        <TextView
                            android:id="@+id/tvFileSize"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.5"
                            android:text="4.2 MB"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter_light"
                            android:textColor="@color/black"
                            android:gravity="end" />

                    </LinearLayout>

<!--                    &lt;!&ndash; Divider &ndash;&gt;-->
<!--                    <View-->
<!--                        android:layout_width="match_parent"-->
<!--                        android:layout_height="1dp"-->
<!--                        android:background="@color/black80"-->
<!--                        android:layout_marginBottom="10dp" />-->

<!--                    &lt;!&ndash; Scan Duration Row &ndash;&gt;-->
<!--                    <LinearLayout-->
<!--                        android:layout_width="match_parent"-->
<!--                        android:layout_height="wrap_content"-->
<!--                        android:orientation="horizontal"-->
<!--                        android:layout_marginBottom="10dp">-->

<!--                        <TextView-->
<!--                            android:layout_width="0dp"-->
<!--                            android:layout_height="wrap_content"-->
<!--                            android:layout_weight="1"-->
<!--                            android:text="Scan Duration"-->
<!--                            android:textSize="13sp"-->
<!--                            android:fontFamily="@font/inter_semibold"-->
<!--                            android:textColor="@color/black" />-->

<!--                        <TextView-->
<!--                            android:id="@+id/tvScanDuration"-->
<!--                            android:layout_width="0dp"-->
<!--                            android:layout_height="wrap_content"-->
<!--                            android:layout_weight="1.5"-->
<!--                            android:text="2.4s"-->
<!--                            android:textSize="13sp"-->
<!--                            android:fontFamily="@font/inter_light"-->
<!--                            android:textColor="@color/black"-->
<!--                            android:gravity="end" />-->

<!--                    </LinearLayout>-->

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/black80"
                        android:layout_marginBottom="10dp" />

                    <!-- Confidence Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Confidence"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter_semibold"
                            android:textColor="@color/black" />

                        <TextView
                            android:id="@+id/tvConfidence"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.5"
                            android:text="98.2%"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter_light"
                            android:textColor="@color/black"
                            android:gravity="end" />

                    </LinearLayout>

                    <!-- Threat Type Row (visible only for malware) -->
                    <View
                        android:id="@+id/dividerThreat"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/black40"
                        android:layout_marginBottom="10dp"
                        android:visibility="gone" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvThreatTypeLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Threat Type"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter_thin"
                            android:textColor="@color/black80"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tvThreatType"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.5"
                            android:text="Trojan.AndroidOS"
                            android:textSize="13sp"
                            android:fontFamily="@font/inter_semibold"
                            android:textColor="@color/black"
                            android:gravity="end"
                            android:visibility="gone" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Summary Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:elevation="2dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="20dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Analysis Summary"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter_bold"
                        android:textColor="@color/black80"
                        android:layout_marginBottom="20dp"
                        />

                    <TextView
                        android:id="@+id/tvResultSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="This file appears to be safe."
                        android:textSize="13sp"
                        android:fontFamily="@font/inter_light"
                        android:textColor="@color/black"
                        android:lineSpacingMultiplier="1.5" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

    <!-- Scan Another File Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnScanAnother"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="32dp"
        android:text="@string/scan_btn"
        android:textSize="14sp"
        android:fontFamily="@font/inter_semibold"
        android:textColor="@color/white"
        app:backgroundTint="@color/dark_pink"
        app:cornerRadius="8dp"
        app:elevation="8dp"
        android:paddingBottom="15dp"
        android:paddingTop="15dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>