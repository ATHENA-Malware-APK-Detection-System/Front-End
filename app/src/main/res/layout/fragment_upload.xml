<!--            android:paddingRight="25dp"-->
<!--            android:paddingBottom="15dp"-->
<!--            app:layout_constraintTop_toBottomOf="@id/uploadDropZone"-->
<!--            app:layout_constraintStart_toStartOf="parent"-->
<!--            app:layout_constraintEnd_toEndOf="parent" />-->

        <!-- Supported Formats -->
        <TextView
            android:id="@+id/tvSupportedLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/supp"
            android:textSize="14sp"
            android:fontFamily="@font/inter_light"
            android:textColor="@color/black80"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/uploadDropZone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/layoutFormats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/tvSupportedLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_light"
                android:background="@drawable/form_border"
                android:elevation="4dp"
                android:text="@string/form"
                android:textAlignment="center"
                android:textColor="@color/black80"
                android:textSize="14sp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>